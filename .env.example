# ===================================================================
# VEDO hub RAG Assistant — Environment Configuration
# ===================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# docker-compose.yml reads these variables automatically.
# ===================================================================

# === Project ===
COMPOSE_PROJECT_NAME=vedo

# === API Security ===
ADMIN_API_KEY=changeme-to-a-long-random-string

# === Database (SQLite) ===
DATABASE_URL=sqlite:/data/vedo.db?mode=rwc

# === OpenRouter (LLM) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Backend ===
BACKEND_PORT=3000
RUST_LOG=info  # dev: debug, prod: warn

# === Embedding Service ===
EMBEDDING_PORT=8001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# === Frontend ===
FRONTEND_PORT=5173

# === Chroma ===
CHROMA_PORT=8000

# === Production (uncomment for deploy) ===
# DOCKER_REGISTRY=ghcr.io
# DOCKER_IMAGE=vedo/vedo-backend
# VERSION=latest
# ALLOWED_ORIGINS=https://vedo.example.com
# CADDY_EMAIL=admin@example.com
