# ===================================================================
# VEDO hub RAG Assistant — Environment Configuration
# ===================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# docker-compose.yml reads these variables automatically.
# ===================================================================

# === Project ===
COMPOSE_PROJECT_NAME=vedo

# === API Security ===
ADMIN_API_KEY=changeme-to-a-long-random-string

# === Database (SQLite) ===
DATABASE_URL=sqlite:/data/vedo.db?mode=rwc

# === OpenRouter (LLM) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# === Backend ===
BACKEND_PORT=3000
RUST_LOG=info  # dev: debug, prod: warn

# === Embedding Service ===
EMBEDDING_PORT=8001
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# === Frontend ===
FRONTEND_PORT=5173

# === KeyCloak ===
KEYCLOAK_DB_PASSWORD=changeme-keycloak-db-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak-admin-password
KEYCLOAK_HOSTNAME=localhost
# vedo-hub realm user passwords (single source of truth)
VEDO_ADMIN_PASSWORD=admin
VEDO_ALICE_PASSWORD=password
VEDO_GUEST_PASSWORD=guest
# Client secret for vedo-backend confidential client
VEDO_BACKEND_CLIENT_SECRET=changeme-vedo-backend-secret
# Social Identity Providers (uncomment and fill to enable)
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=
# MAILRU_CLIENT_ID=
# MAILRU_CLIENT_SECRET=

# === Git Sync ===
# Root directory for cloned git repositories
GIT_CLONE_ROOT=data/git-repos
# Git sync polling interval in seconds (0 = disabled)
GIT_SYNC_INTERVAL_SECS=0

# === Chroma ===
CHROMA_PORT=8000

# === Production (uncomment for deploy) ===
# DOCKER_REGISTRY=ghcr.io
# DOCKER_IMAGE=vedo/vedo-backend
# VERSION=latest
# ALLOWED_ORIGINS=https://vedo.example.com
# CADDY_EMAIL=admin@example.com
